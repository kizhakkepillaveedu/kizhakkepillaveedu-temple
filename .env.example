# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Vercel env vars are configured in the dashboard.

# MongoDB Atlas connection string.
# IMPORTANT: URL-encode any of these characters in the password: @ : / ? #
# e.g. "p@ss" → "p%40ss"
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/DBNAME?appName=APP

# 48+ random bytes used to sign JWT auth cookies.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# The Gmail address that should be the admin. Whoever signs in with this
# Google account is auto-promoted to admin on /api/auth/google.
# `npm run seed` also creates a fallback email/password record with this email.
ADMIN_EMAIL=
ADMIN_PASSWORD=admin123
ADMIN_NAME=Temple Admin

# Images uploaded from the admin panel are stored as binary in MongoDB
# (in the `images` collection) and served via /api/images/<id>.
# No external image-storage service is needed.

# Google Sign-In OAuth Client ID (from https://console.cloud.google.com/auth/clients).
# Public — safe to embed in HTML. Set this in Vercel env vars too.
GOOGLE_CLIENT_ID=
